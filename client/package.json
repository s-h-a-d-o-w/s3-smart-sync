{
  "name": "@s3-smart-sync/client",
  "version": "1.2.0",
  "main": "./src/index.ts",
  "type": "module",
  "scripts": {
    "package": "rimraf dist && pnpm build && pnpm package:pkg && timeout 5 && pnpm silenceexe && pnpm changeicon && wsl ./package-win.sh",
    "package:debug": "rimraf dist && pnpm build && wsl ./package-win-debug.sh",
    "package:linux": "rimraf dist && pnpm build:linux && pnpm package:pkg:linux && ./package-linux.sh",
    "package:sea": "package-sea.bat",
    "package:pkg": "pkg -t node24-win-x64 dist/index.cjs -o s3-smart-sync.exe",
    "package:pkg:linux": "pkg -t node24-linux-x64 dist/index.cjs -o s3-smart-sync",
    "benchmark": "node ./tests/benchmark.ts",
    "build": "rimraf dist && node esbuild.mts && wsl ./copy-addons.sh",
    "build:linux": "rimraf dist && node esbuild.mts && ./copy-addons.sh",
    "changeicon": "exe-edit s3-smart-sync.exe s3-smart-sync.exe --icon ./assets/icon.ico",
    "dev": "node . debug",
    "dev:cli": "node . cli",
    "silenceexe": "create-nodew-exe s3-smart-sync.exe s3-smart-sync.exe",
    "playground": "node playground.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.896.0",
    "@aws-sdk/lib-storage": "^3.896.0",
    "@s3-smart-sync/shared": "workspace:*",
    "auto-launch": "^5.0.6",
    "chokidar": "^5.0.0",
    "dotenv": "^17.4.2",
    "lodash-es": "^4.18.1",
    "node-tray": "^2.0.4",
    "open": "^11.0.0",
    "untildify": "^5.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/auto-launch": "^5.0.5",
    "@types/aws-lambda": "^8.10.152",
    "@types/lodash-es": "^4.17.12",
    "@types/ws": "^8.18.1",
    "@yao-pkg/pkg": "^6.7.0",
    "create-nodew-exe": "^2.1.0",
    "esbuild": "^0.24.2",
    "exe-edit": "^0.1.1",
    "rimraf": "^6.0.1"
  }
}
